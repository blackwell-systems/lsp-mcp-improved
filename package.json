{
  "name": "lsp-mcp-server",
  "version": "0.3.0",
  "description": "MCP server for Language Server Protocol (LSP) integration, providing hover information, code completions, diagnostics, and code actions with resource-based access",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lsp-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "test": "npm run test:typescript && npm run test:prompts && npm run test:diagnostics && npm run test:logging && npm run test:lspClient && npm run test:extensions && npm run test:tools && npm run test:resources",
    "test:typescript": "node test/typescript-lsp.test.js",
    "test:prompts": "node test/prompts.test.js",
    "test:diagnostics": "node test/waitForDiagnostics.test.js",
    "test:logging": "node test/logging.test.js",
    "test:lspClient": "node test/lspClient-helpers.test.js",
    "test:extensions": "node test/extensions.test.js",
    "test:tools": "node test/tools-utils.test.js",
    "test:resources": "node test/resources-utils.test.js",
    "test:multi-lang": "node test/multi-lang.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.8.3",
    "typescript-language-server": "^4.3.4"
  }
}
